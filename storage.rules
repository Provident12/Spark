rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    match /uploads/{allPaths=**} {
      // Anyone signed in can upload and read files
      allow read: if true;
      allow write: if request.auth != null
                   && request.resource.size < 10 * 1024 * 1024; // 10MB limit
    }
  }
}
